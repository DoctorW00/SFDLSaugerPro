QMAKE_TARGET  = SFDLSaugerPro
DESTDIR        = debug\ #avoid trailing-slash linebreak
TARGET         = SFDLSaugerPro.exe
DESTDIR_TARGET = debug\SFDLSaugerPro.exe

####### Implicit rules

.SUFFIXES: .c .cpp .cc .cxx

.cpp.obj:
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -Fo$@ $<

.cc.obj:
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -Fo$@ $<

.cxx.obj:
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -Fo$@ $<

.c.obj:
	$(CC) -c $(CFLAGS) $(INCPATH) -Fo$@ $<

####### Build rules

first: all
all: Makefile.Debug  debug\SFDLSaugerPro.exe

